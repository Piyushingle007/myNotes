{
  "$schema": "https://schema.tauri.app/capability/2.0.0",
  "identifier": "default",
  "description": "Default capability for MyNotes app",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "fs:default",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:allow-read-dir",
    "fs:allow-exists",
    "fs:allow-mkdir",
    "fs:allow-remove",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "fs:allow-stat",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "shell:default",
    "shell:allow-open",
    "store:default",
    "os:default"
  ]
}
